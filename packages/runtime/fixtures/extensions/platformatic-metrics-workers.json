{
  "$schema": "https://schemas.platformatic.dev/@platformatic/runtime/2.0.0.json",
  "entrypoint": "a",
  "extensions": [
    "extension-metrics-1.js"
  ],
  "applications": [
    {
      "id": "a",
      "path": "./services/a"
    },
    {
      "id": "b",
      "path": "./metrics-services/b",
      "workers": 3
    }
  ],
  "server": {
    "hostname": "127.0.0.1",
    "port": "{{PORT}}"
  },
  "logger": {
    "level": "error"
  },
  "metrics": {
    "port": 0
  }
}
