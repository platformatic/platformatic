{
  "$schema": "https://schemas.platformatic.dev/@platformatic/runtime/2.0.0.json",
  "entrypoint": "a",
  "extensions": [
    "extension-metrics-1.js"
  ],
  "autoload": {
    "path": "./services",
    "exclude": ["crash-on-start"]
  },
  "server": {
    "hostname": "127.0.0.1",
    "port": "{{PORT}}"
  },
  "logger": {
    "level": "error"
  },
  "managementApi": true,
  "metrics": {
    "port": 0,
    "labels": {
      "env": "test"
    }
  }
}
