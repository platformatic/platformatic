{
  "$schema": "https://schemas.platformatic.dev/@platformatic/runtime/2.0.0.json",
  "entrypoint": "a",
  "extensions": [
    {
      "path": "./extension-health-api.js",
      "options": {
        "id": "primary"
      }
    }
  ],
  "autoload": {
    "path": "./services",
    "exclude": ["crash-on-start"]
  },
  "server": {
    "hostname": "127.0.0.1",
    "port": "{{PORT}}"
  },
  "metrics": {
    "hostname": "127.0.0.1",
    "port": "{{METRICS_PORT}}"
  },
  "healthProbes": {
    "hostname": "127.0.0.1",
    "port": "{{HEALTH_PORT}}"
  },
  "logger": {
    "level": "error"
  }
}
