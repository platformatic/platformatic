{
  "$schema": "https://schemas.platformatic.dev/@platformatic/runtime/2.0.0.json",
  "entrypoint": "a",
  "extensions": "./extension-health-ready-only.js",
  "autoload": {
    "path": "./services",
    "exclude": ["crash-on-start"]
  },
  "server": {
    "hostname": "127.0.0.1",
    "port": "{{PORT}}"
  },
  "metrics": {
    "hostname": "127.0.0.1",
    "port": "{{METRICS_PORT}}"
  },
  "logger": {
    "level": "error"
  }
}
