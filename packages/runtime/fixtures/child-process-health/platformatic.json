{
  "$schema": "https://schemas.platformatic.dev/@platformatic/runtime/2.6.0.json",
  "watch": false,
  "managementApi": true,
  "restartOnError": 500,
  "entrypoint": "entrypoint",
  "autoload": {
    "path": "."
  },
  "logger": {
    "level": "error"
  },
  "health": {
    "enabled": true,
    "interval": 1000,
    "maxELU": 0.95,
    "maxHeapUsed": 0.95,
    "maxHeapTotal": "512MB"
  }
}
