{
  "$schema": "https://schemas.platformatic.dev/@platformatic/runtime/2.0.0.json",
  "entrypoint": "main",
  "autoload": {
    "path": "./services"
  },
  "server": {
    "hostname": "127.0.0.1",
    "port": 0
  },
  "logger": {
    "level": "error"
  },
  "restartOnError": 100,
  "health": {
    "enabled": true,
    "interval": 1000,
    "gracePeriod": 1,
    "maxUnhealthyChecks": 2,
    "maxEventLoopDelayP99": 100
  }
}
